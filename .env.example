# Sentient Sync Engine — Environment Variables
# Copy this file to .env and fill in the values. NEVER commit .env to source control.

# HMAC-SHA256 key for integrity signing of threat records AND LLM output.
# Generate a secure key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SENTIENT_HMAC_KEY=

# Gemini API key for LLM threat analysis node (llm_analysis_node).
# Obtain from: https://aistudio.google.com/app/apikey
# The engine runs without this key — llm_analysis_node will skip gracefully.
GEMINI_API_KEY=

# Local API base URL (default: http://localhost:8000)
# SENTIENT_API_BASE=http://localhost:8000

# Optional: API token for authenticated endpoint access
# SENTIENT_API_TOKEN=
